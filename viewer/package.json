{
  "name": "star-dump",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.ts --bundle --format=iife --platform=browser --target=es2020 --outfile=dist/main.js && esbuild src/*.worker.ts --bundle --format=esm --platform=browser --target=es2020 --outdir=dist",
    "check": "tsc --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "dev": "esbuild src/main.ts src/*.worker.ts --bundle --format=esm --platform=browser --target=es2020 --outdir=dist --watch --serve=8000 --servedir=."
  },
  "dependencies": {
    "regl": "^2.1.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3"
  }
}
